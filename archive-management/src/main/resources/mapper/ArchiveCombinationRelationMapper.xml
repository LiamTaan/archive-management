<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.electronic.archive.mapper.ArchiveCombinationRelationMapper">
    
    <!-- 根据组合ID查询所有档案组合关系 -->
    <select id="selectByCombinationId" parameterType="java.lang.Long" resultType="com.electronic.archive.entity.ArchiveCombinationRelation">
        SELECT * FROM archive_combination_relation WHERE combination_id = #{combinationId}
    </select>
    
    <!-- 根据档案ID查询所有档案组合关系 -->
    <select id="selectByArchiveId" parameterType="java.lang.Long" resultType="com.electronic.archive.entity.ArchiveCombinationRelation">
        SELECT * FROM archive_combination_relation WHERE archive_id = #{archiveId}
    </select>
    
    <!-- 根据组合ID删除所有档案组合关系 -->
    <delete id="deleteByCombinationId" parameterType="java.lang.Long">
        DELETE FROM archive_combination_relation WHERE combination_id = #{combinationId}
    </delete>
</mapper>