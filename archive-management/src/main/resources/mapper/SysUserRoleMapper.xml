<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.electronic.archive.mapper.SysUserRoleMapper">
    
    <!-- 根据用户ID获取角色ID列表 -->
    <select id="getRoleIdsByUserId" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT role_id FROM sys_user_role WHERE user_id = #{userId}
    </select>
    
    <!-- 根据角色ID获取用户ID列表 -->
    <select id="getUserIdsByRoleId" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT user_id FROM sys_user_role WHERE role_id = #{roleId}
    </select>
    
    <!-- 删除用户的所有角色 -->
    <delete id="deleteByUserId" parameterType="java.lang.Long">
        DELETE FROM sys_user_role WHERE user_id = #{userId}
    </delete>
</mapper>