<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.electronic.archive.mapper.SysDeptMapper">
    
    <!-- 查询部门列表 -->
    <select id="selectDeptList" resultType="com.electronic.archive.entity.SysDept">
        SELECT * FROM sys_dept ORDER BY sort ASC, dept_id ASC
    </select>
    
    <!-- 查询部门树结构 -->
    <select id="selectDeptTree" resultType="com.electronic.archive.entity.SysDept">
        SELECT * FROM sys_dept WHERE status = 1 ORDER BY sort ASC, dept_id ASC
    </select>
    
    <!-- 根据父部门ID查询子部门列表 -->
    <select id="selectChildrenDeptById" parameterType="java.lang.Long" resultType="com.electronic.archive.entity.SysDept">
        SELECT * FROM sys_dept WHERE parent_id = #{parentId} AND status = 1 ORDER BY sort ASC, dept_id ASC
    </select>
</mapper>
